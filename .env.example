# ── Email Configuration ──
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── Ollama / LLM Configuration ──
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_MODEL=deepseek-v4-flash:cloud
OLLAMA_HOST=https://ollama.com

# ── Google Drive / GCS Configuration ──
# Option 1: Use inline JSON (preferred for Docker/Vercel)
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# Option 2: Use a file path (fallback)
GOOGLE_SERVICE_ACCOUNT_FILE=service-account-key.json

# GCS Bucket for reports and data
GCS_BUCKET_NAME=your-bucket-name

# ── Google Drive File Configuration ──
DRIVE_FILE_NAME=Wohlig Active Employee Data.xlsx
DRIVE_FILE_ID=your-google-drive-file-id
OUTPUT_JSON_FILE=all_files_extracted_data.json

# ── Gemini API Key (if used for other features) ──
GEMINI_API_KEY=your-gemini-api-key
